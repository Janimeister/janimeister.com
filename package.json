{
  "name": "janimeister-site",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Personal site for the Janimeister YouTube channel — FromSoftware boss kills.",
  "scripts": {
    "prebuild": "node scripts/fetch-videos.mjs",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "fetch:videos": "node scripts/fetch-videos.mjs",
    "lint": "tsc -b --pretty",
    "test": "jest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "worker:dev": "wrangler dev worker/src/index.ts",
    "worker:deploy": "wrangler deploy"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "tailwindcss": "^4.0.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "wrangler": "^3.90.0"
  }
}
