# Optional: live YouTube feed endpoint exposed by the Cloudflare Worker.
# When set, the site refreshes the video list on load. Without it,
# only the build-time `videos.json` is used (still fully functional).
VITE_VIDEO_API=

# YouTube Data API v3 key from Google Cloud Console.
# Required to fetch more than 15 videos at build time and in the worker.
# Loaded automatically from this file when running `npm run build` or `npm run fetch:videos`
# (uses Node's --env-file-if-exists flag, requires Node >= 22.9.0).
# For the worker, set this as a secret: wrangler secret put YT_API_KEY
# For GitHub Actions, add it as a repository secret named YT_API_KEY.
YT_API_KEY=
