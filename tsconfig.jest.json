{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "noEmit": true,
    "esModuleInterop": true,
    "types": ["jest", "@testing-library/jest-dom"],
    "verbatimModuleSyntax": false
  },
  "include": ["src"]
}
